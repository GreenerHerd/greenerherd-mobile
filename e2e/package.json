{
  "name": "greenerherd-mobile-e2e",
  "private": true,
  "description": "Playwright + Cucumber BDD UI tests for GreenerHerd (Flutter web)",
  "scripts": {
    "bddgen": "bddgen",
    "test": "bddgen && playwright test",
