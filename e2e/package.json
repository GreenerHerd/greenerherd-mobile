    "report": "playwright show-report"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^11.2.0",
    "@playwright/test": "^1.51.0",
    "@types/node": "^22.13.10",
    "playwright-bdd": "^8.2.0",
    "typescript": "^5.8.2"
  }
}
